{
  "root": false,
  "extends": "//",
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!.next",
      "!out",
      "!src/components/ui",
      "!src/generated"
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noUnknownAtRules": "off",
        "noArrayIndexKey": "warn"
      },
      "complexity": {
        "noStaticOnlyClass": "off"
      },
      "style": {
        "noNonNullAssertion": "warn"
      },
      "a11y": {
        "noStaticElementInteractions": "off",
        "useKeyWithClickEvents": "off",
        "noSvgWithoutTitle": "warn"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  }
}
